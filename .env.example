# Polygon wallet private key (with 0x prefix). Required for production mode.
PRIVATE_KEY=

# Polymarket proxy/funder address associated with your account.
POLY_FUNDER_ADDRESS=

# BTC price sources. Comma-separated: polymarket, binance, coinbase
BTC_TICKER=polymarket,binance

# Market window duration: "5m" or "15m"
MARKET_WINDOW=5m

# Simulated wallet balance in USDC (simulation mode only)
WALLET_BALANCE=50

# Maximum cumulative session loss (USD) before auto-shutdown
MAX_SESSION_LOSS=3

# Skip interactive production confirmation prompt
FORCE_PROD=false

# ─── Kalshi weather + whale bot (Kalshi-ww-bot branch) ──────────────
# Kalshi API environment: "demo" (default) or "prod"
KALSHI_ENV=demo

# Kalshi API access key ID (get from Kalshi dashboard → API Keys).
# Not required for the public read endpoints used by the scanners.
KALSHI_ACCESS_KEY=

# RSA private key PEM matching the access key above. Multi-line value;
# paste between quotes or use your shell's heredoc style.
# Required only once we start placing orders.
KALSHI_PRIVATE_KEY_PEM=

# Where to write the shared high-conviction CSV. Default: ./results
RESULTS_DIR=results

# ─── Weather data sources (free tier needs no keys) ─────────────────
# Open-Meteo (default, ECMWF, GFS models) and NOAA NWS are free + keyless
# and are used automatically via src/weather/WeatherEnsemble.ts.
# The adapters below layer on top when keys are configured.

# https://openweathermap.org/api — free tier 1000 calls/day
OPENWEATHER_API_KEY=

# https://docs.tomorrow.io — free tier 500 calls/day
TOMORROW_API_KEY=

# https://www.visualcrossing.com — free tier 1000 records/day
VISUALCROSSING_API_KEY=

# https://www.weatherapi.com — free tier 1M calls/month
WEATHERAPI_API_KEY=

# https://pirateweather.net — free tier 10k calls/month
PIRATEWEATHER_API_KEY=
