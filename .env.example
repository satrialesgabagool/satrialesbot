# Polygon wallet private key (with 0x prefix). Required for production mode.
PRIVATE_KEY=

# Polymarket proxy/funder address associated with your account.
POLY_FUNDER_ADDRESS=

# BTC price sources. Comma-separated: polymarket, binance, coinbase
BTC_TICKER=polymarket,binance

# Market window duration: "5m" or "15m"
MARKET_WINDOW=5m

# Simulated wallet balance in USDC (simulation mode only)
WALLET_BALANCE=50

# Maximum cumulative session loss (USD) before auto-shutdown
MAX_SESSION_LOSS=3

# Skip interactive production confirmation prompt
FORCE_PROD=false
