# ─────────────────────────────────────────────────────────────────
# Satriales — Kalshi Weather Trading Bot
# Copy this file to .env and fill in your own values.
# ─────────────────────────────────────────────────────────────────

# Kalshi API credentials (REQUIRED for live trading)
# Create an RSA key pair in your Kalshi account settings,
# download the private key, and place it somewhere outside the repo.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=/absolute/path/to/your/kalshi-private-key.pem

# Alternative: paste the PEM inline instead of KALSHI_PRIVATE_KEY_PATH
# KALSHI_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# First-order-of-day safety gate (REQUIRED in production; ignored in --demo)
# Set to "yes" on days you want the bot to be allowed to place orders.
# Unset it to park the bot in read-only mode without stopping the process.
KALSHI_CONFIRM_FIRST_ORDER=yes

# NWS (api.weather.gov) User-Agent contact (OPTIONAL)
# NWS recommends an email so they can reach you if your bot misbehaves,
# but it isn't required. Leave blank to send a no-PII User-Agent.
NWS_CONTACT_EMAIL=

# Dashboard HTTP port (OPTIONAL, defaults to 3000)
DASHBOARD_PORT=3000
